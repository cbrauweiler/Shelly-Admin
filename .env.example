# --- Backend ---
PORT=3000

# Verzeichnis fuer die JSON-Datenbank (im Container ein gemountetes Volume).
# Lokal kann das leer bleiben (Standard: ./data).
DATA_DIR=/data

# Steuerungsumfang:
#   full    = Monitoring + Schalten + Reboot + Firmware-Update (Standard)
#   update  = Monitoring + Firmware-Update, aber kein Schalten/Reboot
#   monitor = read-only
CONTROL_MODE=full

# Auto-Refresh der Geraeteliste im Frontend (Sekunden)
REFRESH_SECONDS=15

# --- Discovery (Subnetz-Scan) ---
# Vorbelegung des Scan-Felds, z. B. 192.168.1.0/24 (optional)
DEFAULT_SUBNET=
# Timeout je Geraete-Anfrage und je Scan-Probe (ms) + Parallelitaet
DEVICE_TIMEOUT_MS=2500
SCAN_TIMEOUT_MS=900
SCAN_CONCURRENCY=48

# --- Login / Sessions ---
# Optionales eigenes Cookie-Signier-Geheimnis. Leer = automatisch generiert
# und in der JSON-DB gespeichert (stabil ueber Neustarts).
AUTH_SECRET=
# Hinter HTTPS-Reverse-Proxy UNBEDINGT auf true setzen.
AUTH_COOKIE_SECURE=false
# Session-Dauer in Stunden (Standard 7 Tage)
AUTH_SESSION_HOURS=168
